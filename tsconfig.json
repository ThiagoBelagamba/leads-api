{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "noImplicitThis": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "noImplicitUseStrict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": "./src",
    "paths": {
      "@main/*": ["main/*"],
      "@domain/*": ["main/domain/*"],
      "@config/*": ["main/config/*"],
      "@client/*": ["main/client/*"],
      "@controller/*": ["main/controller/*"],
      "@routes/*": ["main/routes/*"],
      "@middleware/*": ["main/middleware/*"],
      "@dto/*": ["main/dto/*"],
      "@converter/*": ["main/converter/*"],
      "@factory/*": ["main/factory/*"],
      "@exception/*": ["main/exception/*"],
      "@usecase/*": ["main/usecase/*"],
      "@repository/*": ["main/repository/*"],
      "@infra/*": ["main/infrastructure/*"],
      "@infrastructure/*": ["main/infrastructure/*"],
      "@util/*": ["main/util/*"],
      "@container/*": ["main/container/*"],
      "@worker/*": ["main/worker/*"],
      "@/types/*": ["../types/*"],
      "@types/*": ["../types/*"]
    }
  },
  "include": [
    "src/main/infrastructure/web/ApiServer.ts",
    "src/main/routes/PublicLeadCheckoutRoutes.ts",
    "src/main/controller/PublicLeadCheckoutController.ts",
    "src/main/infrastructure/services/AsaasService.ts",
    "src/main/infrastructure/services/EmailService.ts",
    "src/main/infrastructure/config/SmtpConfig.ts",
    "src/main/infrastructure/logging/Logger.ts",
    "src/main/infrastructure/logging/outputs/*.ts"
  ],
  "typeRoots": ["./node_modules/@types"],
  "exclude": [
    "node_modules",
    "src/**/*.test.ts",
    "src/**/*test*.ts",
    "src/__tests__/**/*",
    "src/main/infrastructure/container/demo-migration.ts",
    "src/main/infrastructure/container/migration-entry.ts",
    "src/main/infrastructure/container/production-ready.config.ts",
    "src/main/infrastructure/container/test-hybrid.ts"
  ]
}
