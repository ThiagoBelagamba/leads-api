# Database Configuration (API LeadRapidos — conexão direta Postgres via `pg`)
#
# Postgres local com Docker (na raiz do repo: docker compose up -d):
#   DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:15432/leadrapido_dev
# (porta 15432 no host — ver docker-compose.yml)
#
# Opção 1: URL completa
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# Opção 2: variáveis discretas (senha nunca versionada)
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=
# PGDATABASE=postgres
# TLS (Postgres na VPS / túnel): ex. PGSSLMODE=require
# PGSSLMODE=require
# PGSSL=true
# Validação estrita da cadeia (opcional): PGSSL_REJECT_UNAUTHORIZED=true

DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/scany_dev


# RabbitMQ Configuration (for message queuing)
RABBITMQ_URL=amqp://scany:scany123@localhost:5672


# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=12h

# Node Environment
NODE_ENV=development
PORT=3000

# Client Type (para filtrar endpoints MCP no Swagger)
# Opções: vendas_ia | ph3a | disparo_rapido | lean_quality
# Se não definido, mostra todos os endpoints (útil para desenvolvimento)
CLIENT_TYPE=

# Swagger Configuration
# Ativa logs detalhados do Swagger (filtros, paths, tags)
SWAGGER_VERBOSE=false

# Ativa logs de debug do Swagger (globs, arquivos, build info)
SWAGGER_DEBUG=0

# Ativa logs de registro de visibilidade de endpoints (📝 Registered: GET /path → [clients])
SWAGGER_VISIBILITY_VERBOSE=false

# Logging Configuration
LOG_LEVEL=info

# OpenTelemetry & Application Metadata (for structured logging)
HOSTNAME=localhost
APP_NAME=Leads-Rapido
APP_VERSION=1.0.0

# Slack Notifications (see https://api.slack.com/messaging/webhooks for setup)
SLACK_NOTIFICATIONS_ENABLED=false
SLACK_WEBHOOK_CRITICAL=https://hooks.slack.com/services/your/critical/webhook
SLACK_WEBHOOK_USAGE=https://hooks.slack.com/services/your/usage/webhook
SLACK_WEBHOOK_BUSINESS=https://hooks.slack.com/services/your/business/webhook

# Frontend Configuration (for CORS)
FRONTEND_URL=http://localhost:8080

# Site Disparo Rápido (links em emails: redefinir senha, confirmar email)
SITE_URL=https://disparorapido.com.br
# Logo no header dos emails de boas-vindas (URL completa). Imagem está em site-disparo-rapido/public/images/logo-email.png
EMAIL_LOGO_URL=https://disparorapido.com.br/images/logo-email.png

# PDFs de boas-vindas (volume Docker/Portainer). Caminho dentro do container onde estão os 3 PDFs.
# Ver docs/VOLUME-PDFs-PORTAINER.md. Se não definido, usa /data/welcome-pdfs.
# WELCOME_PDFS_PATH=/data/welcome-pdfs

# ========================================
# Licensing System Configuration
# ========================================

# Modelo 2: CRM SaaS - Session Limits per Plan
PLAN_FREEMIUM_SESSIONS=1
PLAN_STARTER_SESSIONS=2
PLAN_PRO_SESSIONS=5
PLAN_BUSINESS_SESSIONS=7
PLAN_ENTERPRISE_SESSIONS=10

# Modelo 1: Chrome Extension - Trial Configuration
TRIAL_DURATION_DAYS=7
EXPIRATION_WARNING_DAYS=7

# Session Management Token (for /sessions endpoints - short-lived)
SESSION_MANAGEMENT_TOKEN_EXPIRATION=300

# Modelo 3: Marketplace - Default Credit Packages (comma-separated)
CREDIT_PACKAGES=10,50,100,500,1000

# ========================================
# Asaas Payment Gateway Configuration
# ========================================

# Asaas API Credentials
ASAAS_API_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=your_asaas_api_key_here
ASAAS_ENVIRONMENT=sandbox  # sandbox or production

# Webhook Configuration
ASAAS_WEBHOOK_SECRET=your_webhook_secret_here  # For signature validation
CHATWOOT_WEBHOOK_SECRET=your_chatwoot_webhook_secret_here

# Checkout Redirect URLs (for subscription checkout flow)
CHECKOUT_SUCCESS_URL=http://localhost:5173/checkout/success
CHECKOUT_CANCEL_URL=http://localhost:5173/checkout/cancel

# Split de Pagamento (Divisão automática de valores)
# Ative para dividir recebimentos entre múltiplas carteiras Asaas
ASAAS_SPLIT_ENABLED=true  # true para ativar split automático
ASAAS_SPLIT_WALLET_ID=9033e653-de01-4cc5-a532-455e702858e8  # ID da carteira Asaas que receberá a divisão
ASAAS_SPLIT_PERCENTUAL=10.0000  # Percentual do valor líquido (ex: 10.0000 = 10%)
# Nota: percentualValue é aplicado sobre o netValue (após descontar taxas do Asaas)

# Notas Fiscais (NFS-e) - Igual à emissão manual (só escolher o serviço no Asaas)
# Recomendado: use INVOICE_MUNICIPAL_SERVICE_ID com o ID do serviço cadastrado no Asaas (ex: 148872).
# Assim impostos e descrição vêm do serviço; não precisa code/name/taxes no .env.
INVOICE_ON_PAYMENT_CONFIRMED=true
INVOICE_MUNICIPAL_SERVICE_ID=148872
INVOICE_MUNICIPAL_SERVICE_CODE=
INVOICE_MUNICIPAL_SERVICE_NAME=
INVOICE_SERVICE_DESCRIPTION=620230001 | 1.05 - LICENCIAMENTO DE PROGRAMAS DE COMPUTADOR, JOGOS, APLICATIVOS E CONGÊNERES, CUSTOMIZÁVEIS
INVOICE_OBSERVATIONS=

# reCAPTCHA (Backend)
# Chave secreta do reCAPTCHA v2 (https://www.google.com/recaptcha/admin)
RECAPTCHA_SECRET_KEY=6LdlFoUsAAAAAP_WP-v3qVzKcD9j3VPDnbJyY_cB

# ========================================
# Evolution API (WhatsApp notificações internas)
# ========================================

# URL base do servidor Evolution API (sem / no final)
EVOLUTION_SERVER_URL=https://evolution.segurosdecarro.com.br
# Chave de autenticação HTTP (header apikey)
EVOLUTION_API_KEY=your_evolution_api_key_here
# Nome da instância que enviará as notificações
EVOLUTION_INSTANCE_NAME=notificacoes_principal
# Grupo padrão para notificações de novas assinaturas (JID completo)
EVOLUTION_NEW_SUBSCRIPTION_GROUP_ID=120363406832655155@g.us
