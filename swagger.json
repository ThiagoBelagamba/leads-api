{
  "openapi": "3.0.0",
  "info": {
    "title": "Lead Rápido API",
    "version": "1.1.0",
    "description": "API de checkout e entrega de leads do Lead Rápido. Endpoints públicos para catálogo, cálculo (quote), criação de checkout e status, além de webhook Asaas e upload admin de staging."
  },
  "servers": [
    {
      "url": "http://localhost:3000/api/v1",
      "description": "Development"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Saúde do serviço"
    },
    {
      "name": "PublicLeads",
      "description": "Checkout público de leads"
    },
    {
      "name": "Admin",
      "description": "Operações administrativas"
    }
  ],
  "components": {
    "securitySchemes": {},
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "healthy" },
          "timestamp": { "type": "string", "format": "date-time" },
          "service": { "type": "string", "example": "leadrapidos-api" },
          "version": { "type": "string", "example": "1.1.0" }
        },
        "required": ["status", "timestamp", "service", "version"]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "code": { "type": "string", "example": "ROUTE_NOT_FOUND" },
          "message": { "type": "string", "example": "Route GET /foo not found" },
          "requestId": { "type": "string", "example": "c2be4f6c-11f4-4c4a-8c8b-2e7c6b9fdcd2" },
          "timestamp": { "type": "string", "format": "date-time" },
          "details": { "type": "object", "description": "Detalhes adicionais em ambiente de desenvolvimento." }
        },
        "required": ["success", "code", "message", "requestId", "timestamp"]
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" }
        },
        "required": ["success"]
      },
      "CatalogState": {
        "type": "object",
        "properties": {
          "state": { "type": "string", "example": "SP" },
          "segments": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "segment": { "type": "string", "example": "Padaria" },
                "availableLeads": { "type": "integer", "example": 2000 }
              },
              "required": ["segment", "availableLeads"]
            }
          }
        },
        "required": ["state", "segments"]
      },
      "CatalogResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "unitPrice": { "type": "number", "example": 0.01 },
          "minimumAmount": { "type": "number", "example": 0 },
          "states": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CatalogState" }
          }
        },
        "required": ["success", "unitPrice", "minimumAmount", "states"]
      },
      "QuoteResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "state": { "type": "string" },
          "segment": { "type": "string" },
          "unitPrice": { "type": "number" },
          "minimumAmount": { "type": "number" },
          "availableCount": { "type": "integer" },
          "grossAmount": { "type": "number" },
          "discountAmount": { "type": "number" },
          "couponCode": { "type": ["string", "null"] },
          "chargedAmount": { "type": "number" },
          "minimumApplied": { "type": "boolean" }
        },
        "required": ["success", "state", "segment", "unitPrice", "minimumAmount", "availableCount", "grossAmount", "discountAmount", "couponCode", "chargedAmount", "minimumApplied"]
      },
      "CreditCard": {
        "type": "object",
        "properties": {
          "holderName": { "type": "string", "example": "JOAO DA SILVA" },
          "number": { "type": "string", "example": "4111111111111111" },
          "expiryMonth": { "type": ["string", "integer"], "example": "12" },
          "expiryYear": { "type": ["string", "integer"], "example": "2030" },
          "ccv": { "type": "string", "example": "123" }
        },
        "required": ["holderName", "number", "expiryMonth", "expiryYear", "ccv"]
      },
      "CreateCheckoutRequest": {
        "type": "object",
        "properties": {
          "buyerName": { "type": "string" },
          "buyerEmail": { "type": "string" },
          "buyerWhatsapp": { "type": "string" },
          "state": { "type": "string" },
          "segment": { "type": "string" },
          "quantity": { "type": "integer" },
          "paymentMethod": { "type": "string", "enum": ["PIX", "CREDIT_CARD"] },
          "cpfCnpj": { "type": "string" },
          "cep": { "type": "string" },
          "addressNumber": { "type": "string" },
          "endereco": { "type": "string" },
          "bairro": { "type": "string" },
          "cidade": { "type": "string" },
          "uf": { "type": "string" },
          "couponCode": { "type": "string" },
          "creditCard": { "$ref": "#/components/schemas/CreditCard" }
        },
        "required": ["buyerName", "buyerEmail", "buyerWhatsapp", "state", "segment", "quantity", "paymentMethod", "cpfCnpj", "cep", "addressNumber"],
        "oneOf": [
          { "properties": { "paymentMethod": { "const": "PIX" }, "creditCard": { "not": {} } } },
          { "properties": { "paymentMethod": { "const": "CREDIT_CARD" }, "creditCard": { "$ref": "#/components/schemas/CreditCard" } } }
        ]
      },
      "CreateCheckoutResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "purchaseId": { "type": "string" },
          "paymentId": { "type": "string" },
          "paymentStatus": { "type": "string", "example": "PENDING" },
          "invoiceUrl": { "type": ["string", "null"] },
          "chargedAmount": { "type": "number" },
          "grossAmount": { "type": "number" },
          "discountAmount": { "type": "number" },
          "couponCode": { "type": ["string", "null"] },
          "minimumApplied": { "type": "boolean" },
          "pix": {
            "type": "object",
            "properties": {
              "qrCodeImage": { "type": "string", "nullable": true },
              "copyPaste": { "type": "string", "nullable": true }
            },
            "nullable": true
          }
        },
        "required": ["success", "purchaseId", "paymentId", "paymentStatus", "chargedAmount", "grossAmount", "discountAmount", "couponCode", "minimumApplied", "pix"]
      },
      "PaymentStatusResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "paid": { "type": "boolean" },
          "status": { "type": "string" }
        },
        "required": ["success", "paid", "status"]
      },
      "AsaasWebhookPayment": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "AsaasWebhookRequest": {
        "type": "object",
        "properties": {
          "event": { "type": "string", "example": "PAYMENT_RECEIVED" },
          "payment": { "$ref": "#/components/schemas/AsaasWebhookPayment" }
        }
      },
      "UploadStagingRequest": {
        "type": "object",
        "properties": {
          "csvContent": { "type": "string" },
          "delimiter": { "type": "string", "example": "," },
          "fileName": { "type": "string" }
        },
        "required": ["csvContent"]
      },
      "UploadStagingResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "message": { "type": "string" },
          "totalRows": { "type": "integer" },
          "insertedRows": { "type": "integer" }
        },
        "required": ["success", "message", "totalRows", "insertedRows"]
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check (versioned)",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            }
          }
        }
      }
    },
    "/public-leads/catalog": {
      "get": {
        "tags": ["PublicLeads"],
        "summary": "Listar catálogo (estados/segmentos)",
        "responses": {
          "200": {
            "description": "Catálogo retornado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CatalogResponse" }
              }
            }
          }
        }
      }
    },
    "/public-leads/quote": {
      "get": {
        "tags": ["PublicLeads"],
        "summary": "Quote: disponibilidade e cálculo de valor com cupom (opcional)",
        "parameters": [
          { "name": "state", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "segment", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "couponCode", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Quote calculado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/QuoteResponse" }
              }
            }
          },
          "400": {
            "description": "Parâmetros inválidos ou cupom inválido",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "missingStateOrSegment": {
                    "value": {
                      "success": false,
                      "code": "MISSING_STATE_OR_SEGMENT",
                      "message": "state e segment são obrigatórios.",
                      "requestId": "2d3e8b9e-5aac-48be-a289-9a7429f35f20",
                      "timestamp": "2026-03-26T10:00:00.000Z"
                    }
                  },
                  "invalidCoupon": {
                    "value": {
                      "success": false,
                      "code": "INVALID_COUPON",
                      "message": "Cupom inválido ou inativo.",
                      "requestId": "45f8d1cd-8a77-4f0f-a5b2-2f8ad66fb646",
                      "timestamp": "2026-03-26T10:01:00.000Z"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erro interno ao calcular quote",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "quoteCalculationFailed": {
                    "value": {
                      "success": false,
                      "code": "QUOTE_CALCULATION_FAILED",
                      "message": "Erro ao calcular valor.",
                      "requestId": "8ea771af-4b7b-4e54-a64d-d96e7c2e8f18",
                      "timestamp": "2026-03-26T10:02:00.000Z"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/public-leads/create-checkout": {
      "post": {
        "tags": ["PublicLeads"],
        "summary": "Criar checkout (PIX ou cartão de crédito)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateCheckoutRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Checkout criado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateCheckoutResponse" }
              }
            }
          },
          "400": {
            "description": "Validação falhou (estoque, dados, cupom, pagamento)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "invalidPayload": {
                    "value": {
                      "success": false,
                      "code": "INVALID_CHECKOUT_PAYLOAD",
                      "message": "Alguns dados do checkout são inválidos.",
                      "requestId": "7cd21ece-31bd-4b7b-b983-8472eaf03590",
                      "timestamp": "2026-03-26T10:03:00.000Z"
                    }
                  },
                  "invalidCoupon": {
                    "value": {
                      "success": false,
                      "code": "INVALID_COUPON",
                      "message": "Cupom inválido ou inativo.",
                      "requestId": "c87518fc-f42e-438f-bf00-aa3f247bfec6",
                      "timestamp": "2026-03-26T10:04:00.000Z"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erro interno ao criar checkout",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "checkoutCreationFailed": {
                    "value": {
                      "success": false,
                      "code": "CHECKOUT_CREATION_FAILED",
                      "message": "Erro ao criar checkout.",
                      "requestId": "f4504327-5525-454f-8ec0-e6ea5709937d",
                      "timestamp": "2026-03-26T10:05:00.000Z"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/public-leads/payment-status": {
      "get": {
        "tags": ["PublicLeads"],
        "summary": "Consultar status do pagamento (polling)",
        "parameters": [
          { "name": "paymentId", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Status retornado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PaymentStatusResponse" }
              }
            }
          },
          "400": {
            "description": "paymentId inválido",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "missingPaymentId": {
                    "value": {
                      "success": false,
                      "code": "MISSING_PAYMENT_ID",
                      "message": "paymentId é obrigatório.",
                      "requestId": "1d8df031-a627-4f09-a20f-e8ef851ff399",
                      "timestamp": "2026-03-26T10:06:00.000Z"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erro interno ao consultar pagamento",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "paymentStatusCheckFailed": {
                    "value": {
                      "success": false,
                      "code": "PAYMENT_STATUS_CHECK_FAILED",
                      "message": "Erro ao consultar pagamento.",
                      "requestId": "35a71f5f-fd96-4442-a2dd-e76bb62efe31",
                      "timestamp": "2026-03-26T10:07:00.000Z"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/public-leads/webhooks/asaas": {
      "post": {
        "tags": ["PublicLeads"],
        "summary": "Webhook do Asaas para confirmar pagamento",
        "parameters": [
          {
            "name": "asaas-access-token",
            "in": "header",
            "required": true,
            "schema": { "type": "string" },
            "description": "Deve ser igual a ASAAS_WEBHOOK_SECRET (exceto bypass em development)"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AsaasWebhookRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook recebido",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "received": { "type": "boolean" }
                  },
                  "required": ["received"]
                }
              }
            }
          }
        }
      }
    },
    "/public-leads/admin/upload-staging": {
      "post": {
        "tags": ["Admin"],
        "summary": "Upload CSV para inserir dados em leadrapido_staging",
        "parameters": [
          {
            "name": "x-admin-token",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "Token admin (alternativamente pode vir em body.adminToken)"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UploadStagingRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload concluído",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UploadStagingResponse" }
              }
            }
          },
          "400": {
            "description": "CSV inválido",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "missingCsv": {
                    "value": {
                      "success": false,
                      "code": "MISSING_CSV_CONTENT",
                      "message": "csvContent é obrigatório.",
                      "requestId": "39002055-eb2c-4efb-b673-f773117cb760",
                      "timestamp": "2026-03-26T10:08:00.000Z"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "unauthorizedAdmin": {
                    "value": {
                      "success": false,
                      "code": "UNAUTHORIZED_ADMIN",
                      "message": "Não autorizado.",
                      "requestId": "62014a4d-d4df-4f4f-a754-cf54384588ab",
                      "timestamp": "2026-03-26T10:09:00.000Z"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erro interno no upload",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "csvInsertFailed": {
                    "value": {
                      "success": false,
                      "code": "CSV_INSERT_FAILED",
                      "message": "Erro ao inserir CSV: detalhe interno",
                      "requestId": "22fc2f58-9cc8-4ffd-bdd8-1e95b60aaf88",
                      "timestamp": "2026-03-26T10:10:00.000Z"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
